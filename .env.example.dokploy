# Dittofeed on Dokploy — environment template.
# Copy these into Dokploy's "Environment" tab for the compose service
# (or a .env file). Values marked REQUIRED have no safe default.

# --- REQUIRED ---
# Your custom domain (no scheme, no trailing slash). Point its DNS A record
# at the Dokploy server BEFORE deploying so Let's Encrypt can issue a cert.
DOMAIN=dittofeed.example.com

# Dashboard login password (AUTH_MODE=single-tenant). Pick a strong value.
PASSWORD=change-me-strong-password

# App encryption key. Generate once and keep stable:  openssl rand -base64 32
SECRET_KEY=bo4a4xHGdviE9DpSwuYHP8k4REsKexGAyPIVVvg4spA=

# Database / ClickHouse passwords (used by app AND the bundled servers).
DATABASE_PASSWORD=change-me-db-password
CLICKHOUSE_PASSWORD=change-me-clickhouse-password

# --- OPTIONAL (defaults shown) ---
# WORKSPACE_NAME=Default
# AUTH_MODE=single-tenant
# DATABASE_USER=postgres
# CLICKHOUSE_USER=dittofeed

# Image version — keep in sync across lite + admin-cli. Match your repo version.
# IMAGE_TAG=v0.24.0

# Set to false after the first successful boot to skip re-bootstrapping.
# BOOTSTRAP=true

# Memory tuning (MB). LITE_MEM_LIMIT is the node heap; keep it below the
# container limit so the process has headroom.
# LITE_MEM_LIMIT=824
# LITE_CONTAINER_MEM_LIMIT=1024
# CLICKHOUSE_CONTAINER_MEM_LIMIT=2048
